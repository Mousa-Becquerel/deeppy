# DeePPy production reverse proxy — HTTP-only smoke-test mode.
#
# When you're ready to add TLS with a real FQDN, replace the site address line
# below (`:80`) with your domain, e.g.:
#
#     dpp.levery.it {
#         tls m.sondoqah@becquerelinstitute.eu
#         ...
#     }
#
# Caddy auto-issues + renews the Let's Encrypt cert. Everything else in this
# file stays as-is.

:80 {
	# API — everything under /api/ goes to the FastAPI container on the
	# internal compose network.
	handle /api/* {
		reverse_proxy api:8000
	}

	# SPA — everything else is the React build. Fall through to index.html
	# for client-side routes so deep-links like /catalog/xxx work.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	encode gzip zstd

	# Access + error logs → stderr → captured by docker logs.
	log {
		output stderr
		format console
		level INFO
	}

	# Baseline hardening headers on static-file responses. The API sets its
	# own on API responses (H3 middleware in api.py).
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}
}
