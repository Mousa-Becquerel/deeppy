# DeePPy production reverse proxy — TLS mode on deeppy.eu.
#
# Caddy auto-issues + renews a Let's Encrypt cert on first boot. HTTP → HTTPS
# redirect is automatic. To temporarily revert to HTTP-only smoke mode (e.g.
# for a rebuild before DNS is ready), replace the site address line below
# `deeppy.eu` with `:80` and delete the `tls` line.

deeppy.eu {
	# Let's Encrypt uses this email for expiry notices only.
	tls m.sondoqah@becquerelinstitute.eu

	# ── Customer landing pages (bind-mounted static sites) ──
	# The landing repo (deeppy-tech/deeppy-landing) is cloned to
	# /opt/deeppy/static/deeppy-landing on the host and mounted read-only
	# at /srv/static in this container.
	#
	# AGRO.Build.ER — customer landing at https://deeppy.eu/agrobuilder
	# Source: deeppy-landing/public/agribuilder (folder spelled with 'i' in
	# the repo; URL uses 'o' to match the product name AGRO.Build.ER).
	handle_path /agrobuilder/* {
		root * /srv/static/deeppy-landing/public/agribuilder
		try_files {path} /index.html
		file_server
	}
	# Bare /agrobuilder (no trailing slash) → redirect so relative asset
	# paths in the HTML resolve correctly.
	@agrobuilder_bare path /agrobuilder
	redir @agrobuilder_bare /agrobuilder/ 308

	# API — everything under /api/ goes to the FastAPI container on the
	# internal compose network.
	handle /api/* {
		reverse_proxy api:8000
	}

	# SPA — everything else is the React build. Fall through to index.html
	# for client-side routes so deep-links like /catalog/xxx work.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	encode gzip zstd

	# Access + error logs → stderr → captured by docker logs.
	log {
		output stderr
		format console
		level INFO
	}

	# Baseline hardening headers on static-file responses. The API sets its
	# own on API responses (H3 middleware in api.py).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}
}
